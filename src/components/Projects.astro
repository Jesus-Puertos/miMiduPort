---
import TypeScript from "../assets/icons/TypeScript.astro";
import AstroIcon from "../assets/icons/Astro.astro";
import TailwindIcon from "../assets/icons/Tailwind.astro";

const TAGS = {
  TYPESCRIPT: { name: "TypeScript", class: "bg-[#3178C6] text-white", icon: TypeScript },
  ASTRO: { name: "Astro", class: "bg-[#17191E] text-white", icon: AstroIcon },
  TAILWIND: { name: "Tailwind CSS", class: "bg-[#06B6D4]/20 text-white", icon: TailwindIcon },
};

const project = {
  title: "Portal Institucional · H. Ayuntamiento de Zongolica",
  description:
    "Portal oficial del ayuntamiento para acceso a servicios municipales, información institucional, directorio, descargas y transparencia.",
  highlights: [
    "Sitio oficial institucional del municipio",
    "Acceso a servicios, directorio y transparencia",
    "Arquitectura orientada a información pública",
    "Optimización para dispositivos móviles y alto tráfico",
  ],
  link: "https://zongolica.gob.mx/",
  tags: [TAGS.ASTRO, TAGS.TYPESCRIPT, TAGS.TAILWIND],
};
---

<article>
  <h3 class="text-2xl font-semibold text-yellow-800 dark:text-yellow-200 mb-2">
    {project.title}
  </h3>
  <p class="text-lg mb-3 text-pretty">{project.description}</p>
  <ul class="list-disc list-inside text-base mb-4 space-y-1 text-black/70 dark:text-white/70">
    {project.highlights.map((h) => <li>{h}</li>)}
  </ul>
  <ul class="flex flex-wrap gap-x-2 gap-y-1 flex-row mb-4">
    {project.tags.map((tag) => (
      <li>
        <span class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2`}>
          <tag.icon class="size-4" />
          {tag.name}
        </span>
      </li>
    ))}
  </ul>
  <a
    href={project.link}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-x-2 rounded-full border border-black/20 dark:border-white/20 px-4 py-1.5 text-sm hover:bg-black/5 dark:hover:bg-white/10 transition"
  >
    Ver proyecto →
  </a>
  <img
    src="/images/portal_ayuntamiento.png"
    alt="Portal Institucional del H. Ayuntamiento de Zongolica"
    class="mt-6 rounded-xl shadow-2xl w-full object-cover"
    loading="lazy"
  />
</article>
