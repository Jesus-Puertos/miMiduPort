---
import HTMLIcon from "../assets/icons/HTML.astro";
import CSSIcon from "../assets/icons/CSS.astro";
import JavaScriptIcon from "../assets/icons/JavaScript.astro";
import PHPIcon from "../assets/icons/PHP.astro";
import BentoItem from "./BentoItem.astro";
import GithubIcon from "./icons/Github.astro";
import BoxArrowIcon from "./icons/BoxArrow.astro";
import ReactIcon from "../assets/icons/React.astro";
import TailwindIcon from "../assets/icons/Tailwind.astro";
import SpringIcon from "../assets/icons/Spring.astro";
import MySQLIcon from "../assets/icons/MySQL.astro";
import AstroIcon from "../assets/icons/Astro.astro";
import TypeScriptIcon from "../assets/icons/TypeScript.astro";
import WordpressIcon from "@/assets/icons/Wordpress.astro";
import SupabaseIcon from "@/assets/icons/Supabase.astro";
---

<section
  class={`
    w-full max-w-[1400px] mt-8
    grid lg:grid-cols-10 auto-rows-[30rem] gap-4
    mx-auto p-6 md:p-12 lg:p-20
  `}
>
  <!-- Portal Turístico de Zongolica -->
  <BentoItem
    class="col-span-10 md:col-span-6"
    title="Portal Turístico Zongolica"
    subtitle="2026 · En producción"
  >
    <div
      slot="image"
      class="transition-scale absolute bottom-0 left-0 top-0
    -z-10 h-full w-full bg-black-950
    bg-cover bg-top bg-no-repeat opacity-90 bg-blend-luminosity duration-1000 ease-in-out group-hover:scale-110"
      style="background-image: url('/images/portal_turistico.png')"
    >
    </div>
    <p slot="content" class="max-w-xl text-base md:text-lg text-white">
      Plataforma turística para el H. Ayuntamiento de Zongolica con rutas, atractivos, tickets digitales con QR y planificación de visita.
    </p>
    <div slot="tecnologies" class="flex gap-x-2 justify-start items-center">
      <AstroIcon class="size-6 text-white" />
      <ReactIcon class="size-6" />
      <TypeScriptIcon class="size-6" />
      <TailwindIcon class="size-6" />
    </div>
    <div slot="links" class="flex justify-end items-center">
      <span class="overflow-hidden rounded-sm border bg-white/80 shadow-sm flex items-center justify-center">
        <a
          href="https://zongolica.gob.mx/turismo"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-e p-2 text-gray-700 hover:bg-white focus:relative"
        >
          <BoxArrowIcon class="size-5" />
          <span class="sr-only">Ver proyecto</span>
        </a>
      </span>
    </div>
  </BentoItem>

  <!-- IngeTec -->
  <BentoItem
    class="col-span-10 md:col-span-4"
    title="IngeTec"
    subtitle="Marzo 2025"
  >
    <div
      slot="image"
      class="transition-scale absolute bottom-0 left-0 top-0
-z-10 h-full w-full bg-black-950
bg-cover bg-top bg-no-repeat opacity-90 bg-blend-luminosity duration-1000 ease-in-out group-hover:scale-110"
      style="background-image: url('/images/IngeTec.webp')"
    >
    </div>
    <p slot="content" class="max-w-xl text-base md:text-lg text-white">
      Sitio web para el cuerpo académico INGETEC del TECNM Campus Zongolica. Usando Wordpress Headless y Astro Js.
    </p>
    <div slot="tecnologies" class="flex gap-x-2 justify-start items-center">
      <AstroIcon class="size-6 text-white" />
      <TypeScriptIcon class="size-6" />
      <JavaScriptIcon class="size-6" />
      <WordpressIcon class="size-6" />
    </div>
    <div slot="links" class="flex justify-end items-center">
      <span class="overflow-hidden rounded-sm border bg-white/80 shadow-sm flex items-center justify-center">
        <a
          href="https://ingetec-jesus-puertos.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-e p-2 text-gray-700 hover:bg-white focus:relative"
        >
          <BoxArrowIcon class="size-5" />
          <span class="sr-only">Ver demo</span>
        </a>
        <a
          href="https://github.com/Jesus-Puertos/ingetec-astro-version"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-e p-2 text-gray-700 hover:bg-white focus:relative"
        >
          <GithubIcon class="size-5" />
          <span class="sr-only">Abrir en GitHub</span>
        </a>
      </span>
    </div>
  </BentoItem>

  <!-- Sistema de Votación Reinas Feria 2026 -->
  <BentoItem
    class="col-span-10 md:col-span-6"
    title="Votación Reinas · Feria 2026"
    subtitle="Zongolica · Tiempo real"
  >
    <div
      slot="image"
      class="transition-scale absolute bottom-0 left-0 top-0
    -z-10 h-full w-full bg-black-950
    bg-cover bg-top bg-no-repeat opacity-90 bg-blend-luminosity duration-1000 ease-in-out group-hover:scale-110"
      style="background-image: url('/images/sistema_votacion_reinas_feria_zongolica.png')"
    >
    </div>
    <p slot="content" class="max-w-xl text-base md:text-lg text-white">
      Sistema de votación en tiempo real para las reinas de la Feria de Zongolica 2026. Auth con Google, perfiles de candidatas, contador en vivo y tabla de votos con Supabase Realtime.
    </p>
    <div slot="tecnologies" class="flex gap-x-2 justify-start items-center">
      <AstroIcon class="size-6 text-white" />
      <ReactIcon class="size-6" />
      <TypeScriptIcon class="size-6" />
      <TailwindIcon class="size-6" />
      <SupabaseIcon class="size-6" />
    </div>
    <div slot="links" class="flex justify-end items-center">
      <span class="overflow-hidden rounded-sm border bg-white/80 shadow-sm flex items-center justify-center">
        <a
          href="https://zongolica.gob.mx/feria2026/reinas"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-e p-2 text-gray-700 hover:bg-white focus:relative"
        >
          <BoxArrowIcon class="size-5" />
          <span class="sr-only">Ver proyecto</span>
        </a>
      </span>
    </div>
  </BentoItem>

  <!-- BeelTraveler -->
  <BentoItem
    class="col-span-10 md:col-span-4"
    title="BeelTraveler"
    subtitle="HackaTECNM 2024 · 1er lugar regional"
  >
    <div
      slot="image"
      class="transition-scale absolute bottom-0 left-0 top-0
    -z-10 h-full w-full duration-1000 ease-in-out group-hover:scale-110"
      style="background-image: url('/images/beeltraveler.png');"
    >
    </div>
    <p slot="content" class="max-w-xl text-base md:text-lg text-white">
      Plataforma para conectar agencias de turismo con clientes y guías locales. Primer lugar regional en HackaTECNM 2024.
    </p>
    <div slot="tecnologies" class="flex gap-x-2 justify-start items-center">
      <AstroIcon class="size-6 text-white" />
      <ReactIcon class="size-6" />
      <MySQLIcon class="size-6" />
      <TailwindIcon class="size-6" />
    </div>
    <div slot="links" class="flex justify-end items-center">
      <span class="overflow-hidden rounded-sm border bg-white/80 shadow-sm flex items-center justify-center">
        <a
          href="https://beeltraveler-repo-tecnm.vercel.app/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-e p-2 text-gray-700 hover:bg-white focus:relative"
        >
          <BoxArrowIcon class="size-5" />
          <span class="sr-only">Ver demo</span>
        </a>
      </span>
    </div>
  </BentoItem>

  <!-- TECNM Complementarias -->
  <BentoItem
    class="col-span-10 md:col-span-6"
    title="Sistema Complementarias"
    subtitle="TECNM Campus Zongolica"
  >
    <div
      slot="image"
      class="transition-scale absolute bottom-0 left-0 top-0
-z-10 h-full w-full bg-black-950
bg-cover bg-center bg-no-repeat opacity-90 bg-blend-luminosity duration-1000 ease-in-out group-hover:scale-105"
      style="background-image: url('/images/TECNMComplementarias.webp')"
    >
    </div>
    <p slot="content" class="max-w-xl text-base md:text-lg text-white">
      Plataforma integral para el registro de actividades complementarias de estudiantes. Sistema de usuarios, panel de administración y seguridad en formularios.
    </p>
    <div slot="tecnologies" class="flex gap-x-2 justify-start items-center">
      <PHPIcon class="size-6" />
      <JavaScriptIcon class="size-6" />
      <MySQLIcon class="size-6" />
      <CSSIcon class="size-6" />
    </div>
    <div slot="links" class="flex justify-end items-center">
      <span class="overflow-hidden rounded-sm border bg-white/80 shadow-sm flex items-center justify-center">
        <a
          href="https://github.com/Jesus-Puertos/complementarias-proyecto.git"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-e p-2 text-gray-700 hover:bg-white focus:relative"
        >
          <GithubIcon class="size-5" />
          <span class="sr-only">Abrir en GitHub</span>
        </a>
      </span>
    </div>
  </BentoItem>

  <!-- Gatito Millonario -->
  <BentoItem
    class="col-span-10 md:col-span-4"
    title="Gatito Millonario"
    subtitle="Marzo 2023"
  >
    <div
      slot="image"
      class="transition-scale absolute bottom-0 left-0 top-0
-z-10 h-full w-full bg-black-950
bg-cover bg-center bg-no-repeat opacity-90 bg-blend-luminosity duration-1000 ease-in-out group-hover:scale-105"
      style="background-image: url('/images/gatito-millonario.webp')"
    >
    </div>
    <p slot="content" class="max-w-xl text-base md:text-lg text-white">
      Juego para el sitio de cultura tributaria desarrollado con JavaScript y Canvas.
    </p>
    <div slot="tecnologies" class="flex gap-x-2 justify-start items-center">
      <HTMLIcon class="size-8" />
      <CSSIcon class="size-6" />
      <JavaScriptIcon class="size-6" />
    </div>
    <div slot="links" class="flex justify-end items-center">
      <span class="overflow-hidden rounded-sm border bg-white/80 shadow-sm flex items-center justify-center">
        <a
          href="https://github.com/Jesus-Puertos/Gato"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-e p-2 text-gray-700 hover:bg-white focus:relative"
        >
          <GithubIcon class="size-5" />
          <span class="sr-only">Abrir en GitHub</span>
        </a>
      </span>
    </div>
  </BentoItem>

  <!-- Control de Gastos -->
  <BentoItem
    class="col-span-10 md:col-span-6"
    title="Control de Gastos"
    subtitle="Enero 2024"
  >
    <div
      slot="image"
      class="transition-scale absolute bottom-0 left-0 top-0
-z-10 h-full w-full bg-black-950
bg-cover bg-center bg-no-repeat opacity-90 bg-blend-luminosity duration-1000 ease-in-out group-hover:scale-105"
      style="background-image: linear-gradient(to right, rgb(0 0 0 /0.2),rgb(0 0 0 / 0)),url('/images/control-gastos.webp')"
    >
    </div>
    <p slot="content" class="max-w-xl text-base md:text-lg text-white">
      Aplicación de React con CSS puro para controlar gastos mensuales. Incluye Local Storage, filtro por categorías, presupuesto y restante.
    </p>
    <div slot="tecnologies" class="flex gap-x-2 justify-start items-center">
      <ReactIcon class="size-8" />
      <CSSIcon class="size-6" />
    </div>
    <div slot="links" class="flex justify-end items-center">
      <span class="overflow-hidden rounded-sm border bg-white/80 shadow-sm flex items-center justify-center">
        <a
          href="https://control-gastos-appjp.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-e p-2 text-gray-700 hover:bg-white focus:relative"
        >
          <BoxArrowIcon class="size-5" />
          <span class="sr-only">Ver demo</span>
        </a>
        <a
          href="https://github.com/Jesus-Puertos/control-gastos"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-e p-2 text-gray-700 hover:bg-white focus:relative"
        >
          <GithubIcon class="size-5" />
          <span class="sr-only">Abrir en GitHub</span>
        </a>
      </span>
    </div>
  </BentoItem>

  <!-- Sistema de Recursos Humanos -->
  <BentoItem
    class="col-span-10 md:col-span-4"
    title="Sistema de Recursos Humanos"
    subtitle="Enero 2024"
  >
    <div
      slot="image"
      class="transition-scale absolute bottom-0 left-0 top-0
-z-10 h-full w-full bg-black-950
bg-cover bg-center bg-no-repeat opacity-90 bg-blend-luminosity duration-1000 ease-in-out group-hover:scale-105"
      style="background-image: linear-gradient(to right, rgb(0 0 0 /0.4),rgb(0 0 0 / 0)),url('/images/recursos-humanos-proyecto.webp')"
    >
    </div>
    <p slot="content" class="max-w-xl text-base md:text-lg text-white">
      Aplicación FullStack con React y TailwindCSS en el frontend, respaldado por Spring Boot y MySQL en el backend.
    </p>
    <div slot="tecnologies" class="flex gap-x-2 justify-start items-center">
      <ReactIcon class="size-8" />
      <TailwindIcon class="size-6" />
      <SpringIcon class="size-6" />
      <MySQLIcon class="size-6 contrast-50" />
    </div>
  </BentoItem>
</section>
