---
import SunIcon from "../components/icons/Sun.astro";
import MoonIcon from "../components/icons/Moon.astro";
import SystemIcon from "../components/icons/System.astro";
---

<div class="relative ml-1 mr-1" data-theme-toggle>
  <button
    data-theme-btn
    class="appearance-none border-none flex hover:scale-125 transition"
  >
    <span class="sr-only">Elige el tema</span>
    <SunIcon data-theme-icon="light" class="theme-toggle-icon size-5 transition-all" />
    <MoonIcon data-theme-icon="dark" class="theme-toggle-icon absolute size-5 transition-all" />
    <SystemIcon data-theme-icon="system" class="theme-toggle-icon absolute size-5 transition-all" />
  </button>
  <div
    data-themes-menu
    class="absolute opacity-0 scale-80 top-8 right-0 text-sm p-1 min-w-[8rem] rounded-md border border-gray-100 bg-white/70 dark:bg-gray-900/70 dark:border-gray-500/20 shadow-[0_3px_10px_rgb(0,0,0,0.2)] backdrop-blur-md"
  >
    <ul>
      {["Light", "Dark", "System"].map((theme) => (
        <li class="themes-menu-option px-2 py-1.5 cursor-default hover:bg-neutral-400/40 dark:hover:bg-gray-500/50 rounded-sm">
          {theme}
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  [data-themes-menu].open {
    animation: scale-up-center 0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
  }

  @keyframes scale-up-center {
    from { transform: scale(0.8); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }
</style>

<script is:inline>
  function initThemeToggle(root) {
    const matchMedia = window.matchMedia("(prefers-color-scheme: dark)");
    const menu = root.querySelector("[data-themes-menu]");
    const btn  = root.querySelector("[data-theme-btn]");
    let removeListener = null;

    const getThemePreference = () =>
      typeof localStorage !== "undefined"
        ? (localStorage.getItem("theme") ?? "system")
        : matchMedia.matches ? "dark" : "light";

    const updateIcon = (pref) => {
      root.querySelectorAll(".theme-toggle-icon").forEach((el) => {
        el.style.scale = el.dataset.themeIcon === pref ? "1" : "0";
      });
    };

    const updateTheme = () => {
      if (removeListener) removeListener();
      matchMedia.addEventListener("change", updateTheme);
      removeListener = () => matchMedia.removeEventListener("change", updateTheme);

      const pref = getThemePreference();
      const isDark = pref === "dark" || (pref === "system" && matchMedia.matches);
      updateIcon(pref);
      document.documentElement.classList[isDark ? "add" : "remove"]("dark");
    };

    updateTheme();

    document.addEventListener("click", () => menu.classList.remove("open"));

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      menu.classList.toggle("open", !menu.classList.contains("open"));
    });

    root.querySelectorAll(".themes-menu-option").forEach((el) => {
      el.addEventListener("click", (e) => {
        localStorage.setItem("theme", e.target.innerText.toLowerCase().trim());
        updateTheme();
      });
    });
  }

  document.querySelectorAll("[data-theme-toggle]:not([data-initialized])").forEach(root => {
    root.setAttribute("data-initialized", "true");
    initThemeToggle(root);
  });
</script>
