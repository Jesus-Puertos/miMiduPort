<div class="w-full mx-auto lg:w-[740px] mt-5 mb-5">
  <div class="mx-auto max-w-lg text-center">
    <h1 class="text-2xl font-bold sm:text-3xl">¡Empecemos a trabajar hoy!</h1>
    <p class="mt-4 text-gray-500 dark:text-gray-400">
      Envíame un mensaje y te contestaré lo más pronto posible.
    </p>
  </div>

  <form
    action="https://formsubmit.co/jesuspuertos.engineer@gmail.com"
    method="POST"
    class="mx-auto mb-0 mt-8 max-w-md space-y-4"
  >
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="_next" value="https://jesuspuertos.com" />
    <input type="hidden" name="_captcha" value="false" />
    <input type="hidden" name="_subject" value="Nuevo mensaje desde tu portfolio" />

    <div>
      <label for="name" class="sr-only">Nombre</label>
      <input
        name="name"
        id="name"
        type="text"
        class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-neutral-900 text-gray-900 dark:text-white p-4 pe-12 text-sm shadow-sm placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
        placeholder="Tu nombre"
        required
      />
    </div>

    <div>
      <label for="email" class="sr-only">Correo</label>
      <div class="relative">
        <input
          type="email"
          name="email"
          id="email"
          class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-neutral-900 text-gray-900 dark:text-white p-4 pe-12 text-sm shadow-sm placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="Tu correo electrónico"
          required
        />
        <span class="absolute inset-y-0 end-0 grid place-content-center px-4">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 text-gray-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"
            ></path>
          </svg>
        </span>
      </div>
    </div>

    <div>
      <label for="message" class="sr-only">Mensaje</label>
      <textarea
        name="message"
        id="message"
        cols="30"
        rows="5"
        class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-neutral-900 text-gray-900 dark:text-white p-4 text-sm shadow-sm placeholder-gray-400 dark:placeholder-gray-500 resize-none focus:outline-none focus:ring-2 focus:ring-blue-500"
        placeholder="Tu mensaje"
        required></textarea>
    </div>

    <div class="flex items-center justify-between text-balance">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        ¿Prefieres LinkedIn?
        <a
          class="underline hover:text-gray-700 dark:hover:text-gray-200 transition"
          href="https://www.linkedin.com/in/jesus-puertos-mx/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Escríbeme aquí</a
        >
      </p>

      <button
        type="submit"
        class="group relative z-0 h-12 overflow-hidden rounded-md bg-neutral-950 dark:bg-white dark:text-neutral-950 px-8 py-2 text-neutral-50 border border-transparent dark:border-gray-200 transition hover:opacity-90"
      >
        <span class="relative z-10">Enviar</span>
        <span class="absolute inset-0 overflow-hidden rounded-md">
          <span
            class="absolute left-0 aspect-square w-full origin-center translate-x-full rounded-full bg-blue-500 transition-all duration-500 group-hover:-translate-x-0 group-hover:scale-150"
          ></span>
        </span>
      </button>
    </div>
  </form>
</div>
